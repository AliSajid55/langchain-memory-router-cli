# Copy this file to .env and fill in the values.
# PowerShell: Copy-Item .env.example .env

# OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ChatOpenAI-compatible key variable (used by many OpenAI clients)
# Set this to the same OpenRouter key if your code reads OPENAI_API_KEY.
OPENAI_API_KEY=your_openrouter_api_key_here

# Optional: default model and endpoint (if you want env-driven config)
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional headers for OpenRouter
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=LangChain Practice

# Optional LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=LangChain_Practise
